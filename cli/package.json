{
  "name": "winnsen-cli",
  "version": "1.0.0",
  "description": "CLI tool to test Winnsen RS485 locker protocol from laptop",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "list": "node -e \"require('serialport').SerialPort.list().then(p => p.forEach(x => console.log(x.path, x.manufacturer || '', x.vendorId || '')))\""
  },
  "dependencies": {
    "serialport": "^12.0.0"
  }
}
